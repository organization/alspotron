{
  "name": "@alspotron/ui",
  "description": "A UI library for Alspotron",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./css-runtime": {
      "import": "./dist/runtime.js",
      "types": "./dist/runtime-types/runtime.d.ts"
    },
    "./style.css": "./dist/index.css"
  },
  "scripts": {
    "postinstall": "pnpm build",
    "build:vars": "farm build --config ./runtime.farm.config.ts",
    "build:only": "farm build",
    "build": "pnpm build:only && pnpm build:vars"
  },
  "devDependencies": {
    "@farmfe/cli": "1.0.4",
    "@farmfe/core": "1.7.2",
    "@vanilla-extract/vite-plugin": "5.0.1",
    "typescript": "5.8.3",
    "vite-plugin-solid": "2.11.6"
  },
  "peerDependencies": {
    "@floating-ui/dom": "*",
    "@solid-primitives/media": "*",
    "@vanilla-extract/css": "*",
    "@vanilla-extract/dynamic": "*",
    "@vanilla-extract/recipes": "*",
    "solid-js": "*",
    "deepmerge-ts": "*"
  }
}
