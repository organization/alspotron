{
  "name": "@alspotron/shared",
  "description": "A Shared library for Alspotron",
  "main": "./dist/index.js",
  "type": "module",
  "exports": {
    "./renderer": {
      "import": "./dist/renderer/index.js",
      "types": "./dist/types/renderer/index.d.ts"
    }
  },
  "scripts": {
    "postinstall": "pnpm build",
    "build": "pnpm build:renderer",
    "build:renderer": "farm build --config ./renderer.farm.config.ts"
  },
  "devDependencies": {
    "typescript": "5.8.3",
    "@farmfe/core": "1.7.2",
    "@farmfe/js-plugin-dts": "0.6.4",
    "vite-plugin-solid": "2.11.6"
  },
  "dependencies": {},
  "peerDependencies": {
    "solid-js": "1.9.5"
  }
}
